NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

STRIPE_SECRET_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_PRICE_ID_USD=
STRIPE_PRO_PRICE_ID_INR=
STRIPE_PRO_PRICE_ID_DEFAULT=
STRIPE_WEBHOOK_SECRET=
APP_BASE_URL=http://localhost:9002

GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Server-only owner/admin bootstrap. Prefer UIDs once known; emails are useful for first owner bootstrap.
OWNER_EMAILS=
OWNER_UIDS=
ADMIN_EMAILS=
SUPPORT_EMAILS=

# Emergency feature flags. Production checks require explicit true/false values.
ENABLE_ADMIN_CENTER=false
ENABLE_DISCOUNT_ADMIN=false
ENABLE_FILE_CONVERSION=false
ENABLE_STRIPE_CHECKOUT=true
ENABLE_PROMOTION_CODES=false
ENABLE_SUPPORT_ACCESS_REQUESTS=false
ENABLE_MANAGED_OPENROUTER=false

# Quotas, rate limits, and provider allowlists. Tune before public launch.
FREE_DAILY_REQUEST_LIMIT=5
PRO_DAILY_REQUEST_LIMIT=200
PRO_MONTHLY_TOKEN_LIMIT=1000000
MAX_UPLOAD_SIZE_MB=10
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=60
ADMIN_RATE_LIMIT_MAX_REQUESTS=20
OPENROUTER_ALLOWED_MODELS=openai/gpt-4o-mini,anthropic/claude-3.5-haiku,google/gemini-2.0-flash-001,deepseek/deepseek-chat,qwen/qwen-2.5-coder
GEMINI_ALLOWED_MODELS=googleai/gemini-2.0-flash

# Required outside Firebase App Hosting when server-side tier enforcement is enabled.
# Point this to a Firebase service-account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional: path to the Microsoft MarkItDown CLI for document conversion.
# Defaults to `markitdown` when omitted.
MARKITDOWN_COMMAND=
